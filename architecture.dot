// WappFlow Architecture Diagram
// Render with: dot -Tpng architecture.dot -o architecture.png
// Or:          dot -Tsvg architecture.dot -o architecture.svg

digraph WappFlow {
    // ── Global graph settings ─────────────────────────────────────
    graph [
        label       = "WappFlow – WhatsApp Automation Platform\nFull Architecture Diagram"
        labelloc    = t
        fontname    = "Helvetica"
        fontsize    = 20
        fontcolor   = "#1a1a2e"
        bgcolor     = "#f8f9fa"
        rankdir     = TB
        splines     = ortho
        nodesep     = 0.6
        ranksep     = 0.8
        compound    = true
        pad         = 0.5
    ]
    node [fontname="Helvetica" fontsize=11 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=9 color="#555555"]


    // ═══════════════════════════════════════════════════════════════
    // CLUSTER 1 – External Actors
    // ═══════════════════════════════════════════════════════════════
    subgraph cluster_external {
        label       = "External / 3rd-Party"
        style       = dashed
        color       = "#aaaaaa"
        fontcolor   = "#555555"
        fontsize    = 13

        MetaAPI [
            label       = "Meta WhatsApp\nCloud API\n(graph.facebook.com/v18.0)"
            shape       = cylinder
            fillcolor   = "#25D366"
            fontcolor   = white
        ]
        FirebaseAuth [
            label       = "Firebase Auth\n(ID Token Verification)"
            shape       = cylinder
            fillcolor   = "#FFA611"
            fontcolor   = white
        ]
        FirestoreDB [
            label       = "Cloud Firestore\n(Primary Database)"
            shape       = cylinder
            fillcolor   = "#FF6F00"
            fontcolor   = white
        ]
        EndUser [
            label       = "WhatsApp\nEnd User"
            shape       = oval
            fillcolor   = "#128C7E"
            fontcolor   = white
        ]
    }


    // ═══════════════════════════════════════════════════════════════
    // CLUSTER 2 – Frontend (Next.js App)
    // ═══════════════════════════════════════════════════════════════
    subgraph cluster_frontend {
        label       = "Frontend  (Next.js 14 · TypeScript · TailwindCSS)"
        style       = filled
        fillcolor   = "#e8f4fd"
        color       = "#1565C0"
        fontcolor   = "#1565C0"
        fontsize    = 13

        // Pages
        subgraph cluster_pages {
            label     = "Pages (App Router)"
            style     = filled
            fillcolor = "#d0e8fb"
            color     = "#1976D2"

            PageLogin      [label="login/page.tsx\n(Firebase Auth Login)"]
            PageRegister   [label="register/page.tsx\n(Firebase Auth Register)"]
            PageDashboard  [label="dashboard/page.tsx\n(Overview + Stats)"]
            PageBulk       [label="dashboard/bulk-message/\n(Campaign Manager)"]
            PageChatbot    [label="dashboard/chatbot/\n(Chatbot + Rules)"]
            PageFileForward[label="dashboard/file-forward/\n(Media Broadcast)"]
            PageLogs       [label="dashboard/logs/\n(Message Logs)"]
            PageSettings   [label="dashboard/settings/\n(WhatsApp Config)"]
        }

        // Shared FE Modules
        FELayout    [label="DashboardLayout.tsx\n(Sidebar Navigation)"]
        FEAPI       [label="lib/api.ts\n(Axios + Firebase\nToken Interceptor)"]
        FEFirebase  [label="lib/firebase.ts\n(Firebase Client SDK)"]
        FEUtils     [label="lib/utils.ts"]
        FEContexts  [label="contexts/\n(React Contexts)"]
        FEHooks     [label="hooks/\n(Custom Hooks)"]
        FEComponents[label="components/\n(UI: Radix UI +\nTailwindCSS)"]
    }


    // ═══════════════════════════════════════════════════════════════
    // CLUSTER 3 – Backend (FastAPI)
    // ═══════════════════════════════════════════════════════════════
    subgraph cluster_backend {
        label       = "Backend  (FastAPI · Python · Uvicorn :5000)"
        style       = filled
        fillcolor   = "#fff3e0"
        color       = "#E65100"
        fontcolor   = "#E65100"
        fontsize    = 13

        // ── Entry point ───────────────────────────────────────────
        MainApp [
            label     = "main.py\n(FastAPI App · CORS · Middleware\nBackground TTL Cleanup +\nCampaign Scheduler)"
            fillcolor = "#E65100"
            fontcolor = white
            shape     = box
        ]

        // ── Middleware ────────────────────────────────────────────
        subgraph cluster_middleware {
            label     = "Middleware"
            style     = filled
            fillcolor = "#ffe0b2"
            color     = "#BF360C"

            AuthMW [label="auth_middleware.py\nFirebaseAuthMiddleware\n(BearerToken → tenant_id)"]
            CORSMW [label="CORSMiddleware\n(starlette)"]
        }

        // ── Core Infrastructure ───────────────────────────────────
        subgraph cluster_infra {
            label     = "Core Infrastructure"
            style     = filled
            fillcolor = "#fff8e1"
            color     = "#F57F17"

            FirebaseCfg  [label="firebase_config.py\ninit_firebase()\nget_db()"]
            Store        [label="store.py\nget_settings()\nget_chatbot_settings()\nsave_settings()\nactive_campaigns{}"]
            Cache        [label="cache.py\nInMemoryCache\nTTL: 15–120s\n(tenant / chatbot / users)"]
            Observability[label="observability.py\nlog_event()\ntimed_op()"]
            StartupChecks[label="startup_checks.py\nvalidate_environment()"]
        }

        // ── Routers ───────────────────────────────────────────────
        subgraph cluster_routers {
            label     = "API Routers"
            style     = filled
            fillcolor = "#e8f5e9"
            color     = "#2E7D32"
            fontcolor = "#2E7D32"

            RouterWebhook   [label="routers/webhook.py\nGET /api/webhook  (verify)\nPOST /api/webhook (receive)\n─ tenant resolver\n─ status updates\n─ dedup check\n─ button routing\n─ chatbot rules\n─ first_trigger fallback\n─ template pipeline"]
            RouterBulk      [label="routers/bulk_message.py\nGET  /api/bulk-message/templates\nPOST /api/bulk-message/parse\nPOST /api/bulk-message/start\nPOST /api/bulk-message/stop/{id}\nGET  /api/bulk-message/status/{id}\nGET  /api/bulk-message/campaigns\nDELETE /api/bulk-message/campaigns/{id}"]
            RouterChatbot   [label="routers/chatbot.py\nGET/PUT /api/chatbot/settings\nGET/POST/PUT/DELETE /api/chatbot/rules\nGET /api/chatbot/users\nGET /api/chatbot/conversations\nGET /api/chatbot/conversations/{phone}"]
            RouterSettings  [label="routers/settings.py\nGET/POST /api/settings/whatsapp\nPOST /api/settings/whatsapp/test\nGET /api/settings/usage"]
            RouterLogs      [label="routers/logs.py\nGET /api/logs\nGET /api/logs/export\nGET /api/logs/stats"]
            RouterFileForward[label="routers/file_forward.py\nPOST /api/file-forward/send\nPOST /api/file-forward/parse-contacts\nPOST /api/file-forward/send-bulk"]
            RouterChatbotWH [label="routers/webhooks.py\n/chatbot/webhook\n(Legacy chatbot webhook)"]
        }

        // ── Services ──────────────────────────────────────────────
        subgraph cluster_services {
            label     = "Services"
            style     = filled
            fillcolor = "#f3e5f5"
            color     = "#6A1B9A"
            fontcolor = "#6A1B9A"

            SvcWhatsApp   [label="services/whatsapp.py\nWhatsAppService\nsend_text_message()\nsend_template_message()\nsend_image()\nsend_document()\nupload_media()\nget_templates()\ntest_connection()\n(3× retry + backoff)"]
            SvcTemplate   [label="services/template_builder.py\n_template_components{} (cache)\nensure_cached()\nupload_header_media()\nbuild_components()\n(IMAGE/VIDEO/DOC/TEXT headers)"]
            SvcChatGPT    [label="services/chatgpt.py\nget_chatgpt_service()\n(AI fallback – disabled)"]
            WAClient      [label="whatsapp_client.py\n(Legacy WA client\nused by webhooks.py)"]
        }

        // ── DB Layer ─────────────────────────────────────────────
        subgraph cluster_dblayer {
            label     = "db_layer  (Firestore Abstraction)"
            style     = filled
            fillcolor = "#fce4ec"
            color     = "#880E4F"
            fontcolor = "#880E4F"

            DBTenants   [label="db_layer/tenants.py\nget() get_by_phone_number_id()\nupsert()"]
            DBChatbot   [label="db_layer/chatbot.py\nchatbot_config\nchatbot_rules\ncreate/list/update/delete"]
            DBMessages  [label="db_layer/messages.py\nadd() update_status()\nlist_by_tenant()"]
            DBChatMsgs  [label="db_layer/chat_messages.py\nadd()\nget_conversation_list()\nget_user_messages()"]
            DBCampaigns [label="db_layer/campaigns.py\ncreate() get() list()\nupdate_status()\nget_due_scheduled()"]
            DBRecipients[label="db_layer/campaign_recipients.py\ncreate_batch() get_pending()\nupdate_status()\ndelete_by_campaign()"]
            DBCounters  [label="db_layer/campaign_counters.py\ninit_shards() increment() get()"]
            DBWebhookEv [label="db_layer/webhook_events.py\nrecord() exists()\nmark_processed()"]
            DBUsage     [label="db_layer/usage_events.py\nrecord()"]
            DBSecrets   [label="db_layer/secrets.py\nresolve_wa_token()"]
            DBTemplate  [label="db_layer/template_cache.py\ntemplate_cache_db"]
            DBUsers     [label="db_layer/users.py\nusers_db\nshould_send_trigger()\nrecord_trigger()"]
        }
    }


    // ═══════════════════════════════════════════════════════════════
    // CLUSTER 4 – Firestore Collections
    // ═══════════════════════════════════════════════════════════════
    subgraph cluster_firestore {
        label       = "Firestore Collections"
        style       = filled
        fillcolor   = "#fff8e1"
        color       = "#F9A825"
        fontcolor   = "#795548"
        fontsize    = 13

        ColTenants   [label="tenants\n(config + credentials)" shape=note fillcolor="#FFFDE7"]
        ColChatMsgs  [label="chat_messages\n(inbox history, 30d TTL)" shape=note fillcolor="#FFFDE7"]
        ColMessages  [label="messages\n(full msg log, 30d TTL)" shape=note fillcolor="#FFFDE7"]
        ColWebhookEv [label="webhook_events\n(deduplication, 30d TTL)" shape=note fillcolor="#FFFDE7"]
        ColUsage     [label="usage_events\n(billing, 30d TTL)" shape=note fillcolor="#FFFDE7"]
        ColCampaigns [label="campaigns\n(bulk campaign jobs)" shape=note fillcolor="#FFFDE7"]
        ColRecipients[label="campaign_recipients\n(per-contact send status)" shape=note fillcolor="#FFFDE7"]
        ColCounters  [label="campaign_counters\n(sent/failed shards)" shape=note fillcolor="#FFFDE7"]
        ColChatbotCfg[label="chatbot_config\n(enable/fallback)" shape=note fillcolor="#FFFDE7"]
        ColChatbotRules[label="chatbot_rules\n(keyword→response)" shape=note fillcolor="#FFFDE7"]
    }


    // ═══════════════════════════════════════════════════════════════
    // EDGES – Frontend Internal
    // ═══════════════════════════════════════════════════════════════
    PageLogin      -> FEFirebase  [label="signIn"]
    PageRegister   -> FEFirebase  [label="createUser"]
    FEFirebase     -> FEContexts  [label="auth state"]
    FEContexts     -> FELayout
    FELayout       -> PageDashboard
    FELayout       -> PageBulk
    FELayout       -> PageChatbot
    FELayout       -> PageFileForward
    FELayout       -> PageLogs
    FELayout       -> PageSettings
    FEComponents   -> FELayout  [label="UI primitives"]
    FEHooks        -> FEAPI

    // All dashboard pages call the API
    PageDashboard   -> FEAPI
    PageBulk        -> FEAPI
    PageChatbot     -> FEAPI
    PageFileForward -> FEAPI
    PageLogs        -> FEAPI
    PageSettings    -> FEAPI

    // API module attaches Firebase token
    FEAPI -> FEFirebase [label="getIdToken()"]


    // ═══════════════════════════════════════════════════════════════
    // EDGES – Frontend → Backend (HTTP)
    // ═══════════════════════════════════════════════════════════════
    FEAPI -> MainApp [
        label     = "HTTP  (axios)\nAuthorization: Bearer <Firebase ID Token>"
        color     = "#1565C0"
        penwidth  = 2
        lhead     = cluster_backend
    ]


    // ═══════════════════════════════════════════════════════════════
    // EDGES – Backend Internal wiring
    // ═══════════════════════════════════════════════════════════════
    // Startup
    MainApp -> StartupChecks  [label="validate_environment()"]
    MainApp -> FirebaseCfg    [label="init_firebase()"]
    MainApp -> CORSMW
    MainApp -> AuthMW

    // Routers registered in main
    MainApp -> RouterWebhook
    MainApp -> RouterBulk
    MainApp -> RouterChatbot
    MainApp -> RouterSettings
    MainApp -> RouterLogs
    MainApp -> RouterFileForward
    MainApp -> RouterChatbotWH

    // Auth middleware
    AuthMW -> FirebaseCfg [label="verify_id_token()"]

    // Store / Cache
    RouterWebhook    -> Store    [label="get_settings()\nget_chatbot_settings()"]
    RouterBulk       -> Store    [label="get_settings()\nactive_campaigns"]
    RouterChatbot    -> Store    [label="get/save settings\nget rules"]
    RouterSettings   -> Store    [label="get/save settings"]
    Store            -> Cache    [label="get_or_fetch()\ninvalidate()"]
    Store            -> DBTenants
    Store            -> DBChatbot
    Store            -> DBSecrets
    Store            -> DBMessages

    // Webhook router internals
    RouterWebhook -> DBTenants   [label="get_by_phone_number_id()"]
    RouterWebhook -> DBWebhookEv [label="dedup check / record"]
    RouterWebhook -> DBChatMsgs  [label="add incoming/outgoing"]
    RouterWebhook -> DBMessages  [label="add + update_status"]
    RouterWebhook -> DBUsage     [label="record events"]
    RouterWebhook -> DBChatbotRules [label="get_active rules"]
    RouterWebhook -> DBUsers     [label="should_send_trigger()\nrecord_trigger()"]
    RouterWebhook -> Cache       [label="invalidate chat_users"]
    RouterWebhook -> SvcWhatsApp [label="send_text / send_template"]
    RouterWebhook -> SvcTemplate [label="ensure_cached()\nupload_header_media()\nbuild_components()"]

    // Bulk message router internals
    RouterBulk -> DBCampaigns   [label="create/get/list/update"]
    RouterBulk -> DBRecipients  [label="create_batch()\nget_pending()\nupdate_status()"]
    RouterBulk -> DBCounters    [label="init_shards()\nincrement()"]
    RouterBulk -> SvcWhatsApp   [label="send_template\nget_templates"]
    RouterBulk -> SvcTemplate   [label="ensure_cached()\nupload_header_media()\nbuild_components()"]

    // Chatbot router
    RouterChatbot -> DBChatbot  [label="CRUD rules"]
    RouterChatbot -> DBChatMsgs [label="conversations / users"]
    RouterChatbot -> Cache      [label="chat_users cache"]

    // Settings router
    RouterSettings -> SvcWhatsApp [label="test_connection()"]

    // Logs router
    RouterLogs -> DBMessages    [label="list / export"]

    // File Forward router
    RouterFileForward -> SvcWhatsApp [label="send_image / send_doc / send_template"]

    // Legacy chatbot webhooks
    RouterChatbotWH -> WAClient  [label="send_template / send_text"]
    RouterChatbotWH -> DBTenants [label="get_by_phone_number_id()"]
    RouterChatbotWH -> DBUsers   [label="is_user_seen()\nmark_user_seen()"]

    // Services internal
    SvcTemplate -> SvcWhatsApp [label="get_templates() (cache miss)\nupload_media()"]

    // Observability used across routers
    RouterWebhook -> Observability [label="log_event()"]
    RouterBulk    -> Observability [label="log_event()"]


    // ═══════════════════════════════════════════════════════════════
    // EDGES – Backend → External APIs
    // ═══════════════════════════════════════════════════════════════
    SvcWhatsApp -> MetaAPI [
        label    = "HTTPS  (httpx)\nBearer <access_token>\n3× retry + backoff"
        color    = "#25D366"
        penwidth = 2
    ]
    FirebaseCfg -> FirebaseAuth [label="verify_id_token()"]


    // ═══════════════════════════════════════════════════════════════
    // EDGES – DB Layer → Firestore
    // ═══════════════════════════════════════════════════════════════
    DBTenants    -> ColTenants    [color="#FF6F00"]
    DBChatMsgs   -> ColChatMsgs  [color="#FF6F00"]
    DBMessages   -> ColMessages  [color="#FF6F00"]
    DBWebhookEv  -> ColWebhookEv [color="#FF6F00"]
    DBUsage      -> ColUsage     [color="#FF6F00"]
    DBCampaigns  -> ColCampaigns [color="#FF6F00"]
    DBRecipients -> ColRecipients[color="#FF6F00"]
    DBCounters   -> ColCounters  [color="#FF6F00"]
    DBChatbot    -> ColChatbotCfg  [color="#FF6F00"]
    DBChatbot    -> ColChatbotRules[color="#FF6F00"]

    FirestoreDB  -> ColTenants     [style=dashed color="#888"]
    FirestoreDB  -> ColChatMsgs    [style=dashed color="#888"]
    FirestoreDB  -> ColMessages    [style=dashed color="#888"]
    FirestoreDB  -> ColWebhookEv   [style=dashed color="#888"]
    FirestoreDB  -> ColUsage       [style=dashed color="#888"]
    FirestoreDB  -> ColCampaigns   [style=dashed color="#888"]
    FirestoreDB  -> ColRecipients  [style=dashed color="#888"]
    FirestoreDB  -> ColCounters    [style=dashed color="#888"]
    FirestoreDB  -> ColChatbotCfg  [style=dashed color="#888"]
    FirestoreDB  -> ColChatbotRules[style=dashed color="#888"]


    // ═══════════════════════════════════════════════════════════════
    // EDGES – Meta → Backend (incoming webhooks)
    // ═══════════════════════════════════════════════════════════════
    EndUser -> MetaAPI [
        label  = "sends WhatsApp message\nor button reply"
        color  = "#128C7E"
        penwidth = 1.5
    ]
    MetaAPI -> RouterWebhook [
        label    = "POST /api/webhook\n(unauthenticated)"
        color    = "#25D366"
        penwidth = 2
        style    = dashed
    ]
    MetaAPI -> RouterChatbotWH [
        label    = "POST /chatbot/webhook\n(legacy)"
        color    = "#888"
        style    = dashed
    ]
}
