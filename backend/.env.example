# ============================================================================
# WappFlow Backend — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED].
# All others have sensible defaults and can be left commented out.
# ============================================================================


# ── Core / Required ─────────────────────────────────────────────────────────

# [REQUIRED] Postgres connection string (Neon DB or local Postgres)
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# [REQUIRED] Webhook verification token — must match the token configured in
# your Meta App Dashboard under Webhooks > Verify Token.
# Use a strong random string (e.g. openssl rand -hex 32).
WEBHOOK_VERIFY_TOKEN=

# [REQUIRED] Redis host and port for BullMQ queues + rate limiting.
# For managed Redis (e.g. Render, Railway), use REDIS_URL instead.
REDIS_HOST=localhost
REDIS_PORT=6379

# Full Redis URL — if set, overrides REDIS_HOST/REDIS_PORT.
# Example: rediss://default:password@host:port
# REDIS_URL=


# ── Firebase ────────────────────────────────────────────────────────────────

# [REQUIRED FILE] Place your Firebase Admin SDK service account key at:
#   backend/firebase-service-account.json
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key


# ── Server ──────────────────────────────────────────────────────────────────

# Server bind address and port (used by run_server.py)
# HOST=127.0.0.1
# PORT=5000

# Set to "production" to disable /docs, /openapi.json and restrict CORS
ENVIRONMENT=development

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:3000


# ── Encryption ────────────────────────────────────────────────────────────

# [REQUIRED] Fernet encryption key for secrets at rest (tenant tokens, etc.).
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=


# ── Postgres Connection Pool ────────────────────────────────────────────────

# Min/max connections in the async pool
# PG_POOL_MIN=2
# PG_POOL_MAX=15

# Statement timeout for individual queries (milliseconds)
# PG_STATEMENT_TIMEOUT_MS=30000

# Pool-level command timeout (seconds)
# PG_COMMAND_TIMEOUT=60

# Connection retry settings on startup
# PG_CONNECT_RETRIES=10
# PG_CONNECT_RETRY_DELAY_S=1.0

# Session timezone (used for AT TIME ZONE conversions)
# PG_TIMEZONE=Asia/Kolkata


# ── Rate Limiting ───────────────────────────────────────────────────────────

# Worker-side: messages per second per tenant (token bucket)
# TENANT_RATE_LIMIT=16

# Worker-side: max burst capacity per tenant
# TENANT_BURST=20

# Global cooldown (seconds) when WhatsApp returns repeated 429s
# WA_COOLDOWN_TTL=5


# ── BullMQ Worker ──────────────────────────────────────────────────────────

# Global rate limit for the message worker (jobs per second)
# QUEUE_RATE_LIMIT=80

# Max retry attempts for failed message jobs
# QUEUE_RETRY_ATTEMPTS=3

# Seconds before a message without delivery confirmation is re-queued
# DELIVERY_CONFIRM_TIMEOUT_SECONDS=900

# Maximum valid contacts allowed per bulk campaign (default: 500)
# MAX_VALID_CONTACTS=500


# ── Data Retention: Archive (live → archive tables) ────────────────────────
#
# The archive system moves old rows from live tables (messages, chat_messages,
# webhook_events, usage_events) into *_archive tables. This keeps live tables
# small and fast. Dashboard analytics are preserved via daily_message_stats.
#
# Set RETENTION_ENABLED=true to enable the automated background cron.
# You can also run manually: python retention.py

# Master switch for automated background archiving (true/false)
# RETENTION_ENABLED=false

# Hours between automated archive runs
# RETENTION_INTERVAL_HOURS=24

# Max hours per archive run before forced timeout
# RETENTION_TIMEOUT_HOURS=1

# Archive rows older than N days from live tables
# RETENTION_DAYS=30

# Max rows per archive batch (transaction)
# RETENTION_BATCH_SIZE=1000

# Max batches per table per run (safety cap: 1000 × 100 = 100k rows/table)
# RETENTION_MAX_BATCHES=100

# Seconds between archive batches (backpressure / event loop breathing room)
# RETENTION_BATCH_SLEEP=0.05

# SQL statement timeout for archive queries (ms) — higher than default 30s
# RETENTION_STATEMENT_TIMEOUT_MS=120000


# ── Data Retention: Purge (archive tables → deleted) ───────────────────────
#
# The purge system permanently deletes very old rows from *_archive tables.
# Only runs if PURGE_ENABLED=true. Only targets archive tables — never live.
#
# You can also run manually: python retention.py --purge-only

# Master switch for automated archive purge (true/false)
# PURGE_ENABLED=false

# Delete archive rows older than N days (measured by archived_at, not created_at)
# PURGE_RETENTION_DAYS=90

# Max rows per purge batch
# PURGE_BATCH_SIZE=10

# Max batches per table per purge run (safety cap: 10 × 1 = 10 rows/table)
# PURGE_MAX_BATCHES=1

# Seconds between purge batches
# PURGE_BATCH_SLEEP=0.05
